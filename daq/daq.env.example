# Copy this file to daq.env on the DAQ machine and adapt the values.
# The scripts source daq.env automatically from this directory, or the file
# pointed to by MAPMT_DAQ_CONFIG.

# Suite root. Equivalent to the old RICH_SUITE variable, but local to this
# project. If unset, scripts infer it as the parent directory of daq/.
# export MAPMT_SUITE="/path/to/MAPMT_calibration"

# Directory containing ssptest_ConfigureAll, ssptest_ScalerAll, ssptest_TDCAll.
# Legacy CLAS12 RICH default:
MAPMT_DAQ_EXEDIR="${CODA:-}/src/rol/Linux_i686_vme/bin"

# Output directories relative to this suite unless absolute paths are used.
MAPMT_DATA_DIR="data"
MAPMT_PED_DATA_DIR="${MAPMT_DATA_DIR}/ped"
MAPMT_TDC_DATA_DIR="${MAPMT_DATA_DIR}/tdc"
MAPMT_LOG_DIR="${MAPMT_DATA_DIR}/logs"

# DAQ files created by ssptest_* in the current working directory.
MAPMT_SETUP_FILE="setup.txt"
MAPMT_SCALER_PREFIX="ssprich_scaler"
MAPMT_SCALER_OUTFILE="ssprich_countsCTEST0.txt"
MAPMT_TDC_RAW_FILE="ssprich_tdc.bin"

# ssptest_ScalerAll arguments.
MAPMT_Q=0
MAPMT_SCALER_DURATION=2

# ssptest_ConfigureAll defaults.
MAPMT_DEFAULT_THRESHOLD=230
MAPMT_DEFAULT_GAIN=64
MAPMT_DEFAULT_SUPPRESS=0

# Calibration scan defaults.
# gain=0 means "use gain map" in the legacy CLAS12 scripts.
MAPMT_PEDESTAL_START=160
MAPMT_PEDESTAL_STOP=220
MAPMT_PEDESTAL_GAIN=0

MAPMT_DARK_START=100
MAPMT_DARK_STOP=700
MAPMT_DARK_GAIN=0

MAPMT_RATE_RUNS=100
MAPMT_RATE_FIXED_THRESHOLD=230
MAPMT_RATE_GAIN=0

# ssptest_TDCAll defaults. The old script used: ssptest_TDCAll 0 1000000 1.
MAPMT_TDC_THRESHOLD=0
MAPMT_TDC_EVENTS=1000000
MAPMT_TDC_MODE=1
MAPMT_TDC_REPETITIONS=24
MAPMT_TDC_SLEEP=3
MAPMT_TDC_LABEL="BL1_1kHz_F1_W300_LOOKBACK1550"
